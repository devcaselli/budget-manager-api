# Generate RSA key pair (3072-bit recommended; 2048 is the minimum accepted):
# openssl genrsa -out ~/bm-private.pem 3072
# openssl rsa -in ~/bm-private.pem -pubout -out ~/bm-public.pem
# chmod 600 ~/bm-private.pem
APP_JWT_PRIVATE_KEY_PATH=/home/your-user/bm-private.pem
APP_JWT_PUBLIC_KEY_PATH=/home/your-user/bm-public.pem

# Rate limiting (all optional — defaults shown)
# APP_RATE_LIMIT_ENABLED=true
# APP_RATE_LIMIT_TRUST_FORWARDED_FOR=false   # set true only behind a trusted reverse proxy
# APP_RATE_LIMIT_CACHE_MAX_SIZE=10000
# APP_RATE_LIMIT_CACHE_EXPIRY_SECONDS=3600
# APP_RATE_LIMIT_TOKEN_IP_RPM=20             # /auth/token: requests per minute per IP
# APP_RATE_LIMIT_TOKEN_EMAIL_RPH=10          # /auth/token: requests per hour per email
# APP_RATE_LIMIT_REGISTER_IP_RPH=5           # /auth/register: requests per hour per IP
